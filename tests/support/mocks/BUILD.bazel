load("@bazel_skylib//:bzl_library.bzl", "bzl_library")
load(":mocks_tests.bzl", "mocks_test_suite")

package(
    default_visibility = ["//:__subpackages__"],
)

mocks_test_suite(name = "mocks_tests")

bzl_library(
    name = "python_ext",
    srcs = ["python_ext.bzl"],
    deps = [":mocks"],
)

bzl_library(
    name = "mocks",
    srcs = ["mocks.bzl"],
)
