load("@rules_python//python:defs.bzl", "py_binary")

# gazelle:resolve py resolved_package //package2:resolved_package

py_binary(
    name = "relative_imports_bin",
    srcs = ["__main__.py"],
    main = "__main__.py",
    visibility = ["//:__subpackages__"],
    deps = [
        "//package1",
        "//package2",
    ],
)
