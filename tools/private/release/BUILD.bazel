load("@rules_python//python:defs.bzl", "py_binary", "py_library")

package(default_visibility = ["//visibility:public"])

py_library(
    name = "release_lib",
    srcs = glob(["*.py"]),
    deps = [
        "@dev_pip//packaging",
    ],
)

py_binary(
    name = "release",
    srcs = ["release.py"],
    main = "release.py",
    deps = [
        ":release_lib",
    ],
)
