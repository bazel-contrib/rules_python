load("@bazel_gazelle//:def.bzl", "gazelle", "gazelle_binary")

package(
    default_visibility = ["//:__subpackages__"],
)

# Marked manual because we don't need CI to build them.
gazelle_binary(
    name = "gazelle_bin",
    languages = [
        "@bazel_skylib_gazelle_plugin//bzl",
    ],
    tags = ["manual"],
)

gazelle(
    name = "gazelle",
    gazelle = ":gazelle_bin",
    tags = ["manual"],
)
